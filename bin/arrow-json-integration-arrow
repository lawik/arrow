# Archery integration shim: arrow-json-integration-arrow
#
# Forwards to `mix run scripts/json_to_arrow.exs`, run from the
# project root so Mix can find mix.exs. archery's cross-language test
# runner subprocesses this binary by name.

set -euo pipefail

# Resolve project root as the directory two levels up from this script.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$PROJECT_ROOT"
exec mix run scripts/json_to_arrow.exs "$@"
