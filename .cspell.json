{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "useGitignore": true,
  "dictionaryDefinitions": [
    {
      "name": "fhunleth-cspell-dictionary",
      "path": "https://raw.githubusercontent.com/fhunleth/fhunleth-cspell-dictionary/refs/heads/main/words.txt",
      "addWords": false
    }
  ],
  "dictionaries": [
    "elixir",
    "en-gb",
    "fhunleth-cspell-dictionary"
  ],
  "ignorePaths": [
    "deps",
    "_build",
    "assets",
    "mix.exs",
    "priv",
    "test",
    "REVIEW.md",
    "lib/arrow/ipc/flatbuf",
    "integration/archery-elixir.patch"
  ],
  "words": [
    "bigendian",
    "bufs",
    "datagen",
    "fixedsizebinary",
    "fixedsizelist",
    "flatbuf",
    "flatbuffer",
    "flatbuffers",
    "floatingpoint",
    "foobarbaz",
    "largebinary",
    "largelist",
    "largeutf",
    "lawik",
    "littleendian",
    "nanoarrow",
    "parameterises",
    "pipefail",
    "prec",
    "preorder",
    "pyarrow",
    "shareddict",
    "unzoned",
    "venv"
  ]
}
